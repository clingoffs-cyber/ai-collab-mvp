# Backend port for Express
PORT=3000

# Vite environment variable for frontend Socket.io API URL
# Example: http://localhost:3000
VITE_API_URL=

# OpenAI API configuration
# AI_API_KEY: OpenAI API key for personal AI prompts
# AI_MODEL: OpenAI model (gpt-3.5-turbo, gpt-4, gpt-4-turbo, gpt-4o, etc.)
# OPENAI_API_BASE: Optional custom OpenAI API endpoint
AI_API_KEY=
AI_MODEL=gpt-4o
OPENAI_API_BASE=https://api.openai.com/v1

# Google Gemini API configuration (free tier option for testing)
# GEMINI_API_KEY: Google Gemini API key for personal AI prompts
# GEMINI_MODEL: Gemini model (gemini-2.5-flash recommended for free tier)
# If GEMINI_API_KEY is set, Gemini will be used; otherwise falls back to OpenAI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

